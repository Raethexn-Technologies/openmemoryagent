# Quick local dev without Docker (uses SQLite)
# Copy this to .env for rapid local testing:
#   cp .env.sqlite .env && php artisan migrate && php artisan serve

APP_NAME=OpenMemoryAgent
APP_ENV=local
APP_KEY=base64:l7Daapk5Xrryok2y5SvA6RBj0wtei8pZ6ItOAMYzF3k=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync

# ─── LLM Provider ────────────────────────────────────────────────
LLM_PROVIDER=claude
CLAUDE_API_KEY=YOUR_CLAUDE_KEY_HERE
CLAUDE_MODEL=claude-sonnet-4-6
GEMINI_API_KEY=
OPENAI_API_KEY=

# ─── ICP Memory Layer ─────────────────────────────────────────────
ICP_MOCK_MODE=true
ICP_CANISTER_ENDPOINT=http://localhost:4943
ICP_CANISTER_ID=

VITE_APP_NAME="${APP_NAME}"
