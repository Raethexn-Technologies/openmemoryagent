APP_NAME=OpenMemoryAgent
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────────
# Docker (PostgreSQL):
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=open_memory
DB_USERNAME=oma_user
DB_PASSWORD=secret

# Local dev without Docker (SQLite):
# DB_CONNECTION=sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# ─── LLM Provider ────────────────────────────────────────────────
# Options: claude | gemini | openai | openrouter
LLM_PROVIDER=claude

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OpenRouter — one API key, 200+ models (https://openrouter.ai/keys)
# Model examples: anthropic/claude-sonnet-4-5  |  openai/gpt-4o  |  meta-llama/llama-3.1-8b-instruct
# See full list: https://openrouter.ai/models
OPENROUTER_API_KEY=
# Model slugs (see https://openrouter.ai/models for full list):
#   Flagship:  anthropic/claude-sonnet-4.5  |  anthropic/claude-opus-4.5  |  google/gemini-2.5-pro
#   Fast/cheap: google/gemini-2.5-flash     |  google/gemini-2.5-flash-lite
#   Free:      google/gemini-2.5-flash:free |  meta-llama/llama-4-scout:free
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=OpenMemoryAgent

# ─── ICP Memory Layer ─────────────────────────────────────────────
# ICP_MOCK_MODE=true  → stores memories in file cache (no canister needed)
# ICP_MOCK_MODE=false → calls the Node adapter at ICP_CANISTER_ENDPOINT
#
# To run with a real canister:
#   1. cd icp && dfx start --background && dfx deploy
#   2. cd icp/adapter && npm install && ICP_MOCK=false node server.js
#   3. Set ICP_MOCK_MODE=false and ICP_CANISTER_ENDPOINT=http://localhost:3100
ICP_MOCK_MODE=true
ICP_CANISTER_ENDPOINT=http://localhost:3100
ICP_CANISTER_ID=
# ICP_BROWSER_HOST: the URL the *browser* uses to reach dfx or mainnet.
# Local default: http://localhost:4943  |  Mainnet: https://ic0.app
ICP_BROWSER_HOST=http://localhost:4943

VITE_APP_NAME="${APP_NAME}"
